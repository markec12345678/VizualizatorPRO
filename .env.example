# VizualizatorPRO - Okoljske spremenljivke
# Kopiraj v .env: cp .env.example .env

# BAZA (obvezno)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# AI VIZUALIZACIJA (opcijsko - brez tega deluje demo mode)
# Replicate API - za fotorealistične vizualizacije z ControlNet
# Registracija: https://replicate.com
REPLICATE_API_TOKEN=

# EMAIL SERVICE (opcijsko - brez tega se emaili samo log-ajo)
# Resend API - za pošiljanje obvestil o novih leadih
# Registracija: https://resend.com (3000 emailov/mes brezplačno)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
NOTIFICATION_EMAIL=info@vizualizatorpro.si

# ADMIN PANEL (opcijsko - privzeto geslo je v kodi)
# ADMIN_PASSWORD=your-secure-password-here

# NEXTAUTH (opcijsko - za prihodnjo avtentikacijo)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000
