# .editorconfig - dosledno formatiranje kode
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
max_line_length = 100

[*.{json,jsonc,yml,yaml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

[*.{css,scss}]
indent_size = 2

[*.{html,svg}]
indent_size = 2

[*.prisma]
indent_size = 2

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
end_of_line = lf

[*.sql]
indent_size = 2
end_of_line = lf

# GraphQL
[*.graphql]
indent_size = 2

# Environment
[.env*]
indent_size = 2

# Dockerfile
[Dockerfile]
indent_size = 2

# Konfiguracije
[*.config.{js,ts,mjs,cjs}]
indent_size = 2
