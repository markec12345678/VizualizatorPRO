# ==============================================
# VizualizatorPRO - .gitignore
# ==============================================

# Dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
*.lcov
.nyc_output

# Next.js
/.next/
/out/
next-env.d.ts

# Production
/build
/dist

# Misc
.DS_Store
*.pem
Thumbs.db

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dev.log
server.log
dev.out.log

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
.env*.local
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.local
.claude
.z-ai-config

# Database
db/*.db
db/*.db-journal
db/*.sqlite
db/*.sqlite-journal

# Uploads (uporabniške slike)
public/uploads/*
!public/uploads/.gitkeep

# Sandbox specifično (NE commitati)
.zscripts/
.z-ai-config
research/
download/
upload/
skills/
mini-services/
examples/
test
prompt

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Cache
.cache/
.parcel-cache/
.eslintcache
.turbo
*.tsbuildinfo
